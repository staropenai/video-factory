# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ───────────────────────────────────────────────────
/coverage

# ── Build artifacts ───────────────────────────────────────────
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ── Source maps (defense-in-depth: never commit even if generated) ──
*.map

# ── Environment & secrets ─────────────────────────────────────
# .env.example is safe to commit; all others are forbidden
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
.patent-internal/

# ── Debug & logs ──────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── OS / editor artifacts ─────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.bak
*.orig
*.tmp
.vscode/settings.json
.idea/

# ── Data & temp ───────────────────────────────────────────────
.data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
tmp/
temp/

# ── Platform ──────────────────────────────────────────────────
.vercel
.sentryclirc

# ── Internal docs that should not ship ────────────────────────
# (project docs are OK; internal-only docs go here)
.internal/
